# Material thickness scan macro
# Material: Fe, Thickness: 1.9 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial Fe
/Xray/det/SetMaterialSlabThickness 1.9 mm

/run/initialize

# Output directory: /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/Fe/thickness_1.900000
# This is set via environment variable G4_OUTPUT_DIR

/run/beamOn 1000000
