# 材料厚度扫描宏
# 材料： Cu, 厚度： 2.7 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial Cu
/Xray/det/SetMaterialSlabThickness 2.7 mm

/run/initialize

# 输出目录： /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/Cu/thickness_2.700000
# 该路径通过环境变量 G4_OUTPUT_DIR 设置

/run/beamOn 1000000
