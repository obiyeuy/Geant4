# 材料厚度扫描宏
# 材料： Pb, 厚度： 0.077 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial Pb
/Xray/det/SetMaterialSlabThickness 0.077 mm

/run/initialize

# 输出目录： /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/Pb/thickness_0.077000
# 该路径通过环境变量 G4_OUTPUT_DIR 设置

/run/beamOn 10000
