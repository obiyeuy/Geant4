# Material thickness scan macro
# Material: Pb, Thickness: 0.08 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial Pb
/Xray/det/SetMaterialSlabThickness 0.08 mm

/run/initialize

# Output directory: /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/Pb/thickness_0.080000
# This is set via environment variable G4_OUTPUT_DIR

/run/beamOn 1000000
