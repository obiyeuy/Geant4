# Material thickness scan macro
# Material: CHO, Thickness: 40.0 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial CHO
/Xray/det/SetMaterialSlabThickness 40.0 mm

/run/initialize

# Output directory: /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/CHO/thickness_40.000000
# This is set via environment variable G4_OUTPUT_DIR

/run/beamOn 1000000
