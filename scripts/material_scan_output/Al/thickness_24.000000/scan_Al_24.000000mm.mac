# 材料厚度扫描宏
# 材料： Al, 厚度： 24.0 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial Al
/Xray/det/SetMaterialSlabThickness 24.0 mm

/run/initialize

# 输出目录： /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/Al/thickness_24.000000
# 该路径通过环境变量 G4_OUTPUT_DIR 设置

/run/beamOn 1000000
