# 材料厚度扫描宏
# 材料： C, 厚度： 90.0 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial C
/Xray/det/SetMaterialSlabThickness 90.0 mm

/run/initialize

# 输出目录： /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/C/thickness_90.000000
# 该路径通过环境变量 G4_OUTPUT_DIR 设置

/run/beamOn 1000000
