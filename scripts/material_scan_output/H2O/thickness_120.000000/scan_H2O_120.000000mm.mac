# Material thickness scan macro
# Material: H2O, Thickness: 120.0 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial H2O
/Xray/det/SetMaterialSlabThickness 120.0 mm

/run/initialize

# Output directory: /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/H2O/thickness_120.000000
# This is set via environment variable G4_OUTPUT_DIR

/run/beamOn 1000000
