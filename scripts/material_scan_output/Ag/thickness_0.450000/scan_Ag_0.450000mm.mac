# Material thickness scan macro
# Material: Ag, Thickness: 0.45 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial Ag
/Xray/det/SetMaterialSlabThickness 0.45 mm

/run/initialize

# Output directory: /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/Ag/thickness_0.450000
# This is set via environment variable G4_OUTPUT_DIR

/run/beamOn 1000000
