# 材料厚度扫描宏
# 材料： Ag, 厚度： 1.25 mm

/control/verbose 2
/run/verbose 2

/Xray/det/SetMaterialSlabMaterial Ag
/Xray/det/SetMaterialSlabThickness 1.25 mm

/run/initialize

# 输出目录： /home/yyb/workspace/XRay-all/XRay-detectionCode/scripts/material_scan_output/Ag/thickness_1.250000
# 该路径通过环境变量 G4_OUTPUT_DIR 设置

/run/beamOn 1000000
