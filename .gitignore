# === Geant4 编译生成文件 ===
build/
data/
examples/
#bin/
#*.out
#*.exe
# 屏蔽 CMake 产生的中间文件
#CMakeCache.txt
#CMakeFiles/
#CMakeScripts/
#cmake_install.cmake
#Makefile
#install_manifest.txt

# === C++ 相关 ===
#*.o
#*.obj
#*.so
#*.a
#*.lib

# === 数据与输出 (非常重要，防止仓库体积爆炸) ===
# 建议将较大的仿真结果（如 .csv, .root, .dat）排除
#*.root
#*.dat
#*.csv
#*.txt
# 如果你有专门存放原始数据的目录，取消注释下一行
# data/raw/

# === Python 缓存 (如果你用 Python 处理 R 值或 CNN) ===
#__pycache__/
#*.py[cod]
#*$py.class
#.venv/
#venv/
#env/

# === 操作系统与编辑器配置 ===
#.DS_Store
#.vscode/
#.idea/
#*.swp
#*.swo

# === 不排除的文件 (白名单示例) ===
# 确保你的 GDML 文件和必要的宏文件被记录
#!*.gdml
#!*.mac
